{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "environment: bootstrap",
            "type": "shell",
            "command": "bash scripts/bootstrap.sh"
        },
        {
            "label": "db: reset",
            "type": "shell",
            "command": "bash scripts/reset-db.sh"
        },
        {
            "label": "pa1: prepare submission artifacts",
            "type": "shell",
            "command": "bash scripts/prepare-submission.sh",
            "group": "build"
        },
        {
            "label": "containers: logs db",
            "type": "shell",
            "command": "docker compose -f .devcontainer/docker-compose.yml logs --tail=1000 -f db"
        }
    ]
}
