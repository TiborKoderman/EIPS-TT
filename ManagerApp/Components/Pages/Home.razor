@page "/"
@using ManagerApp.Services
@using ManagerApp.Models
@inject IStatisticsService StatisticsService
@inject IWorkerService WorkerService
@inject IGraphService GraphService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<div class="page-header">
    <div class="page-header-main">
        <div>
            <h1 class="page-title">Dashboard</h1>
            <p class="page-subtitle">Overview of crawler statistics and worker status</p>
        </div>
        <HoverTooltip Text="@GetSinceUpdateDetailsText()" Class="header-update-tooltip-wrap">
            <div class="header-updated-pill">
                <span class="mdi mdi-history"></span>
                <span>@GetSinceUpdateCompactText()</span>
            </div>
        </HoverTooltip>
    </div>
</div>

<div class="page-body">
    @if (isLoading)
    {
        <div class="text-center mt-lg">
            <p>Loading statistics...</p>
        </div>
    }
    else if (stats != null)
    {
        <div class="grid grid-cols-4 mb-lg">
            <StatCard Label="Total Sites" Value="@stats.TotalSites.ToString()" Footnote="Crawled domains" />
            <StatCard Label="Total Pages" Value="@stats.TotalPages.ToString()" Footnote="@($"{stats.HtmlPages} HTML pages")" />
            <StatCard Label="Duplicates" Value="@stats.DuplicatePages.ToString()" Footnote="Duplicate detections" />
            <StatCard Label="Images" Value="@stats.TotalImages.ToString()" Footnote="@($"Avg: {stats.AverageImagesPerPage} per page")" />
        </div>

        @if (stats.BinaryFileCounts.Any())
        {
            <div class="card mb-lg">
                <h2 class="card-title">Binary Files</h2>
                <div class="grid grid-cols-4">
                    @foreach (var (type, count) in stats.BinaryFileCounts)
                    {
                        <div>
                            <div class="text-small text-muted">@type</div>
                            <div style="font-size: 20px; font-weight: 600;">@count</div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="dashboard-main-grid mb-lg">
            <div class="card dashboard-worker-status-card">
                <div class="card-header-inline mb-sm">
                    <h2 class="card-title mb-0">Worker Status</h2>
                    <span class="live-pill"><span class="live-dot"></span> Live</span>
                </div>
                @if (workerStatusCounts != null && workerStatusCounts.Any())
                {
                    <div class="dashboard-worker-status">
                        <WorkerStatusPieChart StatusCounts="workerStatusCounts"
                                              SelectedStatus="selectedWorkerStatus"
                                              OnSliceClick="OnWorkerSliceClick" />
                        <div class="dashboard-worker-status-list">
                            @foreach (var status in DashboardStatuses)
                            {
                                var count = workerStatusCounts.GetValueOrDefault(status, 0);
                                <button class="status-row @(selectedWorkerStatus == status ? "active" : "")"
                                        @onclick="() => ToggleWorkerStatus(status)">
                                    <span class="badge @GetStatusBadgeClass(status) status-pill">
                                        <span>@status</span>
                                        <span class="pill-count">@count</span>
                                    </span>
                                </button>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-muted">No workers currently running</p>
                }
            </div>

            <div class="card">
                <div class="card-header-inline">
                    <h2 class="card-title mb-0">Workers Snapshot</h2>
                    <span class="live-pill"><span class="live-dot"></span> Live</span>
                </div>
                @if (visibleWorkers.Count == 0)
                {
                    <p class="text-muted">No workers available.</p>
                }
                else
                {
                    <ul class="list dashboard-worker-list">
                        @foreach (var worker in visibleWorkers.Take(6))
                        {
                            var activity = GetWorkerActivity(worker);
                            <li class="list-item worker-list-clickable" @onclick="() => OpenWorkerDetail(worker.Id)">
                                <div class="flex items-center justify-between gap-sm">
                                    <strong>@worker.Name</strong>
                                    <span class="badge @GetStatusBadgeClass(worker.Status)">@worker.Status</span>
                                </div>
                                <div class="text-small text-muted worker-url-row">
                                    <HoverTooltip Text="@activity.Label" Class="worker-activity-tooltip-wrap">
                                        <span class="mdi @activity.IconClass worker-activity-icon @activity.CssClass"></span>
                                    </HoverTooltip>
                                    <span class="worker-url-processing @(activity.IsProcessing ? "is-processing" : "")">
                                        @(string.IsNullOrWhiteSpace(worker.CurrentUrl) ? "Waiting for next page..." : worker.CurrentUrl) · @worker.Status
                                    </span>
                                    @if (activity.IsProcessing)
                                    {
                                        <span class="processing-ellipsis" aria-hidden="true">
                                            <span></span><span></span><span></span>
                                        </span>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>

            <div class="card dashboard-graph-card">
                <div class="card-header-inline mb-md">
                    <h2 class="card-title mb-0">Node Graph Preview</h2>
                    <div class="flex items-center gap-sm">
                        <button class="btn btn-sm" @onclick="AddMockGraphData">
                            <span class="mdi mdi-database-plus-outline"></span>
                            Add Mock Data
                        </button>
                        <a href="/graph" class="btn btn-primary btn-sm">
                            <span class="mdi mdi-open-in-new"></span>
                            Full View
                        </a>
                    </div>
                </div>

                @if (isGraphLoading)
                {
                    <p class="text-muted">Loading graph preview...</p>
                }
                else if (!string.IsNullOrWhiteSpace(graphError))
                {
                    <p class="text-muted">@graphError</p>
                }
                else if (graphPreview.Nodes.Count == 0)
                {
                    <p class="text-muted">No graph nodes available yet.</p>
                }
                else
                {
                    <ForceGraph Data="graphPreview" Height="360" ShowToolbar="false" />
                }
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <p class="text-muted">Failed to load statistics. Please ensure the database is running.</p>
        </div>
    }
</div>

@code {
    private StatisticsViewModel? stats;
    private Dictionary<string, int>? workerStatusCounts;
    private List<WorkerViewModel> workers = new();
    private GraphDataDto graphPreview = new();
    private string? graphError;
    private string? selectedWorkerStatus;
    private bool isLoading = true;
    private bool isGraphLoading = true;
    private PeriodicTimer? refreshTimer;
    private CancellationTokenSource? refreshCts;
    private readonly SemaphoreSlim workerRefreshLock = new(1, 1);
    private static readonly string[] DashboardStatuses = ["Active", "Idle", "Paused", "Error", "Stopped"];
    private DateTime lastDashboardUpdateUtc = DateTime.UtcNow;

    private List<WorkerViewModel> visibleWorkers => workers
        .Where(w => selectedWorkerStatus == null || string.Equals(w.Status, selectedWorkerStatus, StringComparison.OrdinalIgnoreCase))
        .OrderBy(w => w.Name)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            stats = await StatisticsService.GetStatisticsAsync();
            lastDashboardUpdateUtc = DateTime.UtcNow;
            await RefreshWorkersAsync();
            await LoadGraphPreviewAsync();
            StartWorkerRefreshLoop();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard data: {ex.Message}");
            stats = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadGraphPreviewAsync()
    {
        isGraphLoading = true;
        graphError = null;

        try
        {
            graphPreview = await GraphService.GetGraphDataAsync(120);
            lastDashboardUpdateUtc = DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            graphError = $"Unable to load graph preview: {ex.Message}";
        }
        finally
        {
            isGraphLoading = false;
        }
    }

    private async Task AddMockGraphData()
    {
        try
        {
            await GraphService.AddMockGraphDataAsync(120);
            await LoadGraphPreviewAsync();
            stats = await StatisticsService.GetStatisticsAsync();
            lastDashboardUpdateUtc = DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            graphError = $"Unable to add mock graph data: {ex.Message}";
        }
    }

    private void StartWorkerRefreshLoop()
    {
        refreshCts = new CancellationTokenSource();
        refreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(4));
        _ = PollWorkersAsync(refreshTimer, refreshCts.Token);
    }

    private async Task PollWorkersAsync(PeriodicTimer timer, CancellationToken cancellationToken)
    {
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await RefreshWorkersAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Normal shutdown path when leaving the page.
        }
    }

    private async Task RefreshWorkersAsync()
    {
        if (!await workerRefreshLock.WaitAsync(0))
        {
            return;
        }

        try
        {
            workerStatusCounts = await WorkerService.GetWorkerStatusCountsAsync();
            workers = await WorkerService.GetAllWorkersAsync();
            lastDashboardUpdateUtc = DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error refreshing worker snapshot: {ex.Message}");
        }
        finally
        {
            workerRefreshLock.Release();
        }
    }

    private Task OnWorkerSliceClick(string status)
    {
        ToggleWorkerStatus(status);
        return Task.CompletedTask;
    }

    private void ToggleWorkerStatus(string status)
    {
        selectedWorkerStatus = string.Equals(selectedWorkerStatus, status, StringComparison.OrdinalIgnoreCase)
            ? null
            : status;
    }

    private string GetStatusBadgeClass(string status)
    {
        return status.ToLowerInvariant() switch
        {
            "active" => "badge-success",
            "error" => "badge-error",
            "idle" => "badge-info",
            "paused" => "badge-warning",
            _ => "badge-info"
        };
    }

    private static WorkerActivity GetWorkerActivity(WorkerViewModel worker)
    {
        var status = worker.Status.ToLowerInvariant();

        if (status == "error")
        {
            return new WorkerActivity("mdi-alert-circle-outline", "Issue", "activity-error", false);
        }

        if (status is "idle" or "stopped")
        {
            return new WorkerActivity("mdi-sleep", "Waiting", "activity-waiting", false);
        }

        if (status == "paused")
        {
            return new WorkerActivity("mdi-pause-circle-outline", "Paused", "activity-paused", false);
        }

        if (status == "active")
        {
            var isParsing = (worker.PagesProcessed + worker.ErrorCount + worker.Id) % 2 == 0;
            return isParsing
                ? new WorkerActivity("mdi-file-code-outline", "Parsing", "activity-parsing", true)
                : new WorkerActivity("mdi-magnify", "Searching", "activity-searching", true);
        }

        return new WorkerActivity("mdi-cog-outline", "Processing", "activity-processing", true);
    }

    private readonly record struct WorkerActivity(string IconClass, string Label, string CssClass, bool IsProcessing);

    private void OpenWorkerDetail(int workerId)
    {
        Navigation.NavigateTo($"/workers/{workerId}");
    }

    private string GetSinceUpdateCompactText()
    {
        var seconds = Math.Max(0, (int)(DateTime.UtcNow - lastDashboardUpdateUtc).TotalSeconds);
        return $"{seconds}s";
    }

    private string GetSinceUpdateDetailsText()
    {
        var seconds = Math.Max(0, (int)(DateTime.UtcNow - lastDashboardUpdateUtc).TotalSeconds);
        return $"{seconds}s since last dashboard update (stats, workers, and graph preview refresh).";
    }

    public ValueTask DisposeAsync()
    {
        refreshCts?.Cancel();
        refreshTimer?.Dispose();
        refreshCts?.Dispose();
        workerRefreshLock.Dispose();
        return ValueTask.CompletedTask;
    }
}

