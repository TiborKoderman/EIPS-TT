@page "/pages"
@using ManagerApp.Data
@using ManagerApp.Models
@using ManagerApp.Services
@inject IPageService PageService
@implements IAsyncDisposable

<div class="page-header">
    <h1 class="page-title">Collected Pages</h1>
    <p class="page-subtitle">Search indexed pages and inspect crawl metadata</p>
</div>

<div class="page-body">
    <div class="card mb-lg pages-toolbar-card">
        <div class="pages-toolbar-row">
            <div class="pages-search-shell">
                <span class="mdi mdi-magnify pages-search-icon" aria-hidden="true"></span>
                <input
                    class="pages-search-input"
                    type="search"
                    placeholder="Search URL or page content..."
                    value="@SearchTerm"
                    @oninput="OnSearchInput" />
            </div>

            <div class="pages-filter-shell">
                <span class="mdi mdi-filter-variant pages-filter-icon" aria-hidden="true"></span>
                <select value="@PageTypeFilter" @onchange="OnFilterChanged">
                    <option value="ALL">All page types</option>
                    <option value="HTML">HTML</option>
                    <option value="BINARY">BINARY</option>
                    <option value="DUPLICATE">DUPLICATE</option>
                    <option value="FRONTIER">FRONTIER</option>
                </select>
            </div>

            <button class="btn btn-primary pages-search-button" @onclick="() => ReloadAsync(keepSelection: true)">
                <span class="mdi mdi-magnify"></span>
                <span>Search</span>
            </button>

            <span class="live-pill"><span class="live-dot"></span> Live</span>
            <span class="text-small text-muted">updated @GetSinceUpdateText()</span>
        </div>
    </div>

    <div class="grid grid-cols-2">
        <div class="card">
            <h2 class="card-title">Results (@Total)</h2>
            @if (Rows.Count == 0)
            {
                <p class="text-muted">No pages found for current query.</p>
            }
            else
            {
                <div class="page-results-table-wrap">
                    <table class="workers-log-table page-results-table">
                        <thead>
                            <tr>
                                <th>TS</th>
                                <th>Type</th>
                                <th>HTTP</th>
                                <th>URL</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Rows)
                            {
                                <tr class="page-row @(SelectedPage?.Id == row.Id ? "selected" : "")"
                                    @onclick="() => SelectPage(row.Id)">
                                    <td class="workers-log-ts">@(row.AccessedTime.HasValue ? row.AccessedTime.Value.ToLocalTime().ToString("HH:mm:ss") : "-")</td>
                                    <td>
                                        <span class="badge badge-info">@row.PageType</span>
                                        @if (row.IsDuplicate)
                                        {
                                            <span class="badge badge-warning">Dup</span>
                                        }
                                    </td>
                                    <td>@(row.HttpStatus?.ToString() ?? "-")</td>
                                    <td>
                                        <div class="page-url">@row.Url</div>
                                        <div class="text-small text-muted">@(string.IsNullOrWhiteSpace(row.SiteDomain) ? "-" : row.SiteDomain)</div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="card">
            <h2 class="card-title">Details</h2>
            @if (SelectedPage == null)
            {
                <p class="text-muted">Select a result to show page metadata.</p>
            }
            else
            {
                <div class="flex flex-col gap-sm">
                    <div><strong>URL:</strong> @SelectedPage.Url</div>
                    <div><strong>Type:</strong> @SelectedPage.PageTypeCode</div>
                    <div><strong>HTTP:</strong> @SelectedPage.HttpStatusCode</div>
                    <div><strong>Accessed:</strong> @SelectedPage.AccessedTime</div>
                    <div><strong>Images:</strong> @SelectedPage.Images.Count</div>
                    <div><strong>Binary blobs:</strong> @SelectedPage.PageData.Count</div>
                    <a class="btn mt-md" href="/graph">
                        <span class="mdi mdi-graph-outline"></span> Show on Graph
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string SearchTerm { get; set; } = "";
    private string PageTypeFilter { get; set; } = "ALL";
    private int Total;

    private List<PageSearchDto> Rows = new();
    private Page? SelectedPage;
    private PeriodicTimer? _liveTimer;
    private CancellationTokenSource? _liveCts;
    private CancellationTokenSource? _searchDebounceCts;
    private DateTime _lastUpdatedUtc = DateTime.UtcNow;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync(keepSelection: false);

        _liveCts = new CancellationTokenSource();
        _liveTimer = new PeriodicTimer(TimeSpan.FromSeconds(3));
        _ = Task.Run(async () =>
        {
            while (_liveTimer is not null && await _liveTimer.WaitForNextTickAsync(_liveCts.Token))
            {
                await InvokeAsync(async () =>
                {
                    await ReloadAsync(keepSelection: true);
                    StateHasChanged();
                });
            }
        }, _liveCts.Token);
    }

    private async Task OnSearchInput(ChangeEventArgs args)
    {
        SearchTerm = args.Value?.ToString() ?? string.Empty;

        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _searchDebounceCts = new CancellationTokenSource();

        try
        {
            await Task.Delay(280, _searchDebounceCts.Token);
            await ReloadAsync(keepSelection: true);
        }
        catch (OperationCanceledException)
        {
            // New input arrived before debounce interval finished.
        }
    }

    private async Task OnFilterChanged(ChangeEventArgs args)
    {
        PageTypeFilter = args.Value?.ToString() ?? "ALL";
        await ReloadAsync(keepSelection: true);
    }

    private async Task ReloadAsync(bool keepSelection)
    {
        var selectedId = keepSelection ? SelectedPage?.Id : null;
        Rows = await PageService.SearchPagesAsync(SearchTerm, PageTypeFilter, 0, 120);
        Total = await PageService.GetSearchResultsCountAsync(SearchTerm, PageTypeFilter);
        _lastUpdatedUtc = DateTime.UtcNow;

        if (Rows.Count == 0)
        {
            SelectedPage = null;
            return;
        }

        if (selectedId.HasValue && Rows.Any(row => row.Id == selectedId.Value))
        {
            await SelectPage(selectedId.Value);
        }
        else
        {
            await SelectPage(Rows[0].Id);
        }
    }

    private async Task SelectPage(int pageId)
    {
        SelectedPage = await PageService.GetPageDetailsAsync(pageId);
    }

    private string GetSinceUpdateText()
    {
        var seconds = Math.Max(0, (int)(DateTime.UtcNow - _lastUpdatedUtc).TotalSeconds);
        return $"{seconds}s ago";
    }

    public ValueTask DisposeAsync()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();

        try
        {
            _liveCts?.Cancel();
        }
        catch
        {
            // Ignore shutdown race when cancelling live timer.
        }

        _liveTimer?.Dispose();
        _liveCts?.Dispose();
        return ValueTask.CompletedTask;
    }
}
