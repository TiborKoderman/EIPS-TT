    private static List<WorkerLogEntryViewModel> BuildLogsFromCrawlerEvents(
        IReadOnlyList<CrawlerEventViewModel> events,
        int limit,
        string? severity,
        string? search)
    {
        var normalizedSeverity = string.IsNullOrWhiteSpace(severity)
            || string.Equals(severity, "all", StringComparison.OrdinalIgnoreCase)
            ? null
            : severity.Trim();
        var normalizedSearch = string.IsNullOrWhiteSpace(search) ? null : search.Trim();

        var rows = events
            .OrderByDescending(evt => evt.TimestampUtc)
            .Select(evt => new WorkerLogEntryViewModel
            {
                TimestampUtc = evt.TimestampUtc,
                Level = ResolveEventLevel(evt.Type, evt.PayloadJson),
                Message = FormatEventMessage(evt.Type, evt.PayloadJson),
                DaemonId = string.IsNullOrWhiteSpace(evt.DaemonId) ? "local-default" : evt.DaemonId,
                WorkerId = evt.WorkerId,
            });

        if (!string.IsNullOrWhiteSpace(normalizedSeverity))
        {
            rows = rows.Where(log => string.Equals(log.Level, normalizedSeverity, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(normalizedSearch))
        {
            rows = rows.Where(log => log.Message.Contains(normalizedSearch, StringComparison.OrdinalIgnoreCase));
        }

        return rows.Take(Math.Clamp(limit, 1, 400)).ToList();
    }

    private static string InferLevelFromEventType(string eventType)
    {
        var normalized = (eventType ?? string.Empty).Trim().ToLowerInvariant();
        if (normalized.Contains("error") || normalized.Contains("failed"))
        {
            return "Error";
        }

        if (normalized.Contains("warn"))
        {
            return "Warning";
        }

        return "Info";
    }

    private static string ResolveEventLevel(string eventType, string payloadJson)
    {
        try
        {
            using var document = JsonDocument.Parse(payloadJson);
            if (document.RootElement.ValueKind == JsonValueKind.Object
                && document.RootElement.TryGetProperty("level", out var levelElement)
                && levelElement.ValueKind == JsonValueKind.String)
            {
                var level = levelElement.GetString();
                if (!string.IsNullOrWhiteSpace(level))
                {
                    return level.Trim();
                }
            }
        }
        catch
        {
            // fall back to event type inference below
        }

        return InferLevelFromEventType(eventType);
    }

    private static string FormatEventMessage(string eventType, string payloadJson)
    {
        try
        {
            using var document = JsonDocument.Parse(payloadJson);
            if (document.RootElement.ValueKind != JsonValueKind.Object)
            {
                return $"[{eventType}] {payloadJson}";
            }

            if (document.RootElement.TryGetProperty("message", out var messageElement)
                && messageElement.ValueKind == JsonValueKind.String)
            {
                var message = messageElement.GetString();
                if (!string.IsNullOrWhiteSpace(message))
                {
                    if ((string.Equals(eventType, "worker-metric", StringComparison.OrdinalIgnoreCase)
                        || (string.Equals(eventType, "worker-log", StringComparison.OrdinalIgnoreCase)
                            && message.Contains("[worker-metric]", StringComparison.OrdinalIgnoreCase)))
                        && TryFormatMetricMessage(message.Trim(), out var metricMessage))
                    {
                        return metricMessage;
                    }

                    return string.Equals(eventType, "worker-log", StringComparison.OrdinalIgnoreCase)
                        ? message.Trim()
                        : $"[{eventType}] {message.Trim()}";
                }
            }

            var parts = new List<string>();
            AppendPayloadPart(parts, document.RootElement, "previousStatus");
            AppendPayloadPart(parts, document.RootElement, "status");
            AppendPayloadPart(parts, document.RootElement, "reason");
            AppendPayloadPart(parts, document.RootElement, "url");
            AppendPayloadPart(parts, document.RootElement, "name");
            AppendPayloadPart(parts, document.RootElement, "inMemoryQueued");
            AppendPayloadPart(parts, document.RootElement, "localQueued");
            AppendPayloadPart(parts, document.RootElement, "activeLeases");
            AppendPayloadPart(parts, document.RootElement, "knownUrls");
            AppendPayloadPart(parts, document.RootElement, "error");
            AppendPayloadPart(parts, document.RootElement, "pages_processed_total");
            AppendPayloadPart(parts, document.RootElement, "errors_total");
            AppendPayloadPart(parts, document.RootElement, "page_processed");
            AppendPayloadPart(parts, document.RootElement, "page_error");

            if (parts.Count > 0)
            {
                return $"[{eventType}] {string.Join(" | ", parts)}";
            }
        }
        catch
        {
            // keep raw payload if parsing fails
        }

        return $"[{eventType}] {payloadJson}";
    }

    private static void AppendPayloadPart(List<string> parts, JsonElement root, string key)
    {
        if (!root.TryGetProperty(key, out var value))
        {
            return;
        }

        var text = value.ValueKind switch
        {
            JsonValueKind.String => value.GetString(),
            JsonValueKind.Number => value.GetRawText(),
            JsonValueKind.True => "true",
            JsonValueKind.False => "false",
            _ => null,
        };

        if (!string.IsNullOrWhiteSpace(text))
        {
            parts.Add($"{key}={text}");
        }
    }

    private static List<WorkerThroughputPointViewModel> BuildThroughputSeriesFromCrawlerEvents(
        IReadOnlyList<CrawlerEventViewModel> events,
        int windowMinutes,
        int bucketSeconds)
    {
        var windowStart = DateTime.UtcNow.AddMinutes(-Math.Clamp(windowMinutes, 5, 24 * 60));
        var boundedBucket = Math.Clamp(bucketSeconds, 10, 600);
        var bucketSums = new Dictionary<DateTime, double>();

        foreach (var evt in events)
        {
            if (evt.TimestampUtc < windowStart)
            {
                continue;
            }

            if (!TryParseMetricIncrement(evt.PayloadJson, out var increment) || increment <= 0)
            {
                continue;
            }

            var bucket = FloorToBucketUtc(evt.TimestampUtc, boundedBucket);
            bucketSums[bucket] = bucketSums.TryGetValue(bucket, out var current) ? current + increment : increment;
        }

        return bucketSums
            .OrderBy(item => item.Key)
            .Select(item => new WorkerThroughputPointViewModel
            {
                TimestampUtc = item.Key,
                Value = item.Value,
            })
            .ToList();
    }

    private static bool TryParseMetricIncrement(string payloadJson, out double value)
    {
        value = 0;

        if (string.IsNullOrWhiteSpace(payloadJson))
        {
            return false;
        }

        try
        {
            using var document = JsonDocument.Parse(payloadJson);
            if (document.RootElement.ValueKind != JsonValueKind.Object)
            {
                return false;
            }

            if (document.RootElement.TryGetProperty("type", out var typeElement)
                && typeElement.ValueKind == JsonValueKind.String
                && string.Equals(typeElement.GetString(), "page-reported", StringComparison.OrdinalIgnoreCase))
            {
                value = 1;
                return true;
            }

            if (document.RootElement.TryGetProperty("page_processed", out var pageProcessed)
                && TryReadNumericValue(pageProcessed, out var parsedIncrement))
            {
                value = parsedIncrement;
                return true;
            }

            if (document.RootElement.TryGetProperty("metric_value", out var metricValue)
                && TryReadNumericValue(metricValue, out var parsedMetricValue))
            {
                value = parsedMetricValue;
                return true;
            }

            if (document.RootElement.TryGetProperty("event_type", out var eventType)
                && eventType.ValueKind == JsonValueKind.String
                && string.Equals(eventType.GetString(), "page-reported", StringComparison.OrdinalIgnoreCase))
            {
                value = 1;
                return true;
            }

            if (document.RootElement.TryGetProperty("status", out var statusElement)
                && statusElement.ValueKind == JsonValueKind.String
                && string.Equals(statusElement.GetString(), "Active", StringComparison.OrdinalIgnoreCase)
                && document.RootElement.TryGetProperty("url", out var urlElement)
                && urlElement.ValueKind == JsonValueKind.String)
            {
                value = 1;
                return true;
            }

            if (document.RootElement.TryGetProperty("message", out var messageElement)
                && messageElement.ValueKind == JsonValueKind.String)
            {
                return TryParseMetricIncrementFromString(messageElement.GetString(), out value);
            }
        }
        catch
        {
            return false;
        }

        return false;
    }

    private static bool TryParseMetricIncrementFromString(string? metricText, out double value)
    {
        value = 0;
        if (string.IsNullOrWhiteSpace(metricText))
        {
            return false;
        }

        var candidate = metricText.Trim();
        var firstBrace = candidate.IndexOf('{');
        if (firstBrace >= 0)
        {
            candidate = candidate[firstBrace..];
        }

        try
        {
            using var nestedDoc = JsonDocument.Parse(candidate);
            if (nestedDoc.RootElement.ValueKind != JsonValueKind.Object)
            {
                return false;
            }

            if (nestedDoc.RootElement.TryGetProperty("page_processed", out var pageProcessed)
                && TryReadNumericValue(pageProcessed, out var parsedIncrement))
            {
                value = parsedIncrement;
                return true;
            }

            if (nestedDoc.RootElement.TryGetProperty("metric_value", out var metricValue)
                && TryReadNumericValue(metricValue, out var parsedMetricValue))
            {
                value = parsedMetricValue;
                return true;
            }

            if (nestedDoc.RootElement.TryGetProperty("type", out var typeElement)
                && typeElement.ValueKind == JsonValueKind.String
                && string.Equals(typeElement.GetString(), "page-reported", StringComparison.OrdinalIgnoreCase))
            {
                value = 1;
                return true;
            }

            if (nestedDoc.RootElement.TryGetProperty("event_type", out var eventType)
                && eventType.ValueKind == JsonValueKind.String
                && string.Equals(eventType.GetString(), "page-reported", StringComparison.OrdinalIgnoreCase))
            {
                value = 1;
                return true;
            }
        }
        catch
        {
            return false;
        }

        return false;
    }

    private static bool TryReadNumericValue(JsonElement element, out double value)
    {
        value = 0;
        if (element.ValueKind == JsonValueKind.Number)
        {
            return element.TryGetDouble(out value);
        }

        if (element.ValueKind == JsonValueKind.String)
        {
            return double.TryParse(element.GetString(), out value);
        }

        return false;
    }

    private static bool TryFormatMetricMessage(string metricText, out string formatted)
    {
        formatted = string.Empty;
        var candidate = metricText;
        var firstBrace = candidate.IndexOf('{');
        if (firstBrace >= 0)
        {
            candidate = candidate[firstBrace..];
        }

        try
        {
            using var document = JsonDocument.Parse(candidate);
            if (document.RootElement.ValueKind != JsonValueKind.Object)
            {
                return false;
            }

            var parts = new List<string>();
            AppendPayloadPart(parts, document.RootElement, "pages_processed_total");
            AppendPayloadPart(parts, document.RootElement, "errors_total");
            AppendPayloadPart(parts, document.RootElement, "page_processed");
            AppendPayloadPart(parts, document.RootElement, "page_error");
            AppendPayloadPart(parts, document.RootElement, "frontier_in_memory");
            AppendPayloadPart(parts, document.RootElement, "frontier_leases");

            if (parts.Count == 0)
            {
                return false;
            }

            formatted = $"[worker-metric] {string.Join(" | ", parts)}";
            return true;
        }
        catch
        {
            return false;
        }
    }

    private static DateTime FloorToBucketUtc(DateTime timestampUtc, int bucketSeconds)
    {
        var normalized = timestampUtc.Kind == DateTimeKind.Utc
            ? timestampUtc
            : DateTime.SpecifyKind(timestampUtc, DateTimeKind.Utc);
        var ticksPerBucket = TimeSpan.FromSeconds(bucketSeconds).Ticks;
        var flooredTicks = normalized.Ticks - (normalized.Ticks % ticksPerBucket);
        return new DateTime(flooredTicks, DateTimeKind.Utc);
    }

    private readonly record struct WorkerActivity(string IconClass, string Label, string CssClass, bool IsProcessing);

    private void ToggleDaemonExpand(WorkerGroupSettingsViewModel daemon)
    {
        var key = GetDaemonExpandKey(daemon);
        if (!expandedDaemonIds.Add(key))
        {
            expandedDaemonIds.Remove(key);
        }
    }

    private void OpenWorkerDetail(int workerId, string? daemonId = null)
    {
        var normalizedDaemonId = NormalizeDaemonId(daemonId);
        Navigation.NavigateTo($"/workers/{workerId}?daemonId={Uri.EscapeDataString(normalizedDaemonId)}");
    }

    private void OpenWorkerSection(int workerId, string section, string? daemonId = null)
    {
        var normalizedDaemonId = NormalizeDaemonId(daemonId);
        Navigation.NavigateTo($"/workers/{workerId}/{section}?daemonId={Uri.EscapeDataString(normalizedDaemonId)}");
    }

    private static string NormalizeDaemonId(string? daemonId)
    {
        return string.IsNullOrWhiteSpace(daemonId) ? "local-default" : daemonId.Trim();
    }

    private static string GetDaemonExpandKey(WorkerGroupSettingsViewModel daemon)
    {
        return $"{NormalizeDaemonId(daemon.DaemonId)}:{daemon.Id}";
    }

    public ValueTask DisposeAsync()
    {
        try
        {
            _refreshCts?.Cancel();
        }
        catch
        {
            // ignore shutdown cancellation race
        }

        _refreshTimer?.Dispose();
        _refreshCts?.Dispose();
        return ValueTask.CompletedTask;
    }
