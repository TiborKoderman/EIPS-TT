@page "/workers"
@using System.Text.Json
@using ManagerApp.Models
@using ManagerApp.Services
@implements IAsyncDisposable
@inject IWorkerService WorkerService
@inject DaemonChannelService DaemonChannel
@inject NavigationManager Navigation

<div class="page-header">
    <div class="page-header-main">
        <div>
            <h1 class="page-title">Workers</h1>
            <p class="page-subtitle">Manage workers inside crawler daemons (one daemon process can run multiple workers)</p>
        </div>
        <div class="flex items-center gap-sm">
            <a class="btn btn-icon" href="/workers/strategy" title="Worker strategy" aria-label="Worker strategy">
                <span class="mdi mdi-vector-polyline"></span>
            </a>
            <a class="btn btn-icon" href="/workers/config" title="Global worker config" aria-label="Global worker config">
                <span class="mdi mdi-cog-outline"></span>
            </a>
            <a class="btn btn-icon" href="/workers/groups" title="Daemon config" aria-label="Daemon config">
                <span class="mdi mdi-server-cog"></span>
            </a>
            <div class="header-updated-pill">
                <span class="mdi mdi-server"></span>
                <span>Daemon: @(daemonStatus?.Running == true ? "Running" : "Stopped")</span>
            </div>
            <div class="header-updated-pill">
                <span class="mdi mdi-robot"></span>
                <span>@workerItems.Count workers</span>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="card mb-lg workers-filter-card">
        <div class="flex items-center justify-between gap-md workers-filter-row">
            <div class="flex items-center gap-md">
                <input type="search" placeholder="Filter workers by name or URL..." @bind="SearchTerm" @bind:event="oninput" />
                <select @bind="StatusFilter">
                    <option value="ALL">All statuses</option>
                    @foreach (var status in Statuses)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
                <select @bind="SpawnGroupId">
                    @foreach (var daemon in SpawnableDaemons)
                    {
                        <option value="@daemon.Id">@daemon.Name</option>
                    }
                </select>
                <select @bind="SpawnMode">
                    <option value="thread">OS Thread</option>
                    <option value="local">Local Process</option>
                </select>
            </div>
            <div class="flex items-center gap-sm">
                <input type="text" placeholder="Worker name (optional)" @bind="SpawnWorkerName" />
                <button class="btn btn-primary" @onclick="QuickStartCrawling">
                    <span class="mdi mdi-rocket-launch-outline"></span> Quick Start
                </button>
                <button class="btn btn-primary" @onclick="SpawnWorker" disabled="@(daemonStatus?.Running != true)">
                    <span class="mdi mdi-plus"></span> Add Worker
                </button>
                <button class="btn" @onclick="ToggleDaemon">
                    <span class="mdi @(daemonStatus?.Running == true ? "mdi-stop-circle-outline" : "mdi-play-circle-outline")"></span>
                    @(daemonStatus?.Running == true ? "Stop Daemon" : "Start Daemon")
                </button>
                <button class="btn" @onclick="ReloadDaemon" disabled="@(daemonStatus?.Running != true)">
                    <span class="mdi mdi-refresh"></span> Reload
                </button>
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(actionStatus))
        {
            <p class="text-small text-muted mt-sm">@actionStatus</p>
        }
        <textarea class="spawn-seed-textarea mt-sm" rows="3" placeholder="Seed URLs (one per line)" @bind="SpawnSeedUrlsText"></textarea>
    </div>

    <div class="card mb-lg">
        <h2 class="card-title">Daemon Channel Diagnostics</h2>
        <div class="grid grid-cols-4 mb-md">
            <StatCard Label="Connected Daemons" Value="@daemonConnections.Count.ToString()" Footnote="WebSocket channel" />
            <StatCard Label="Queued" Value="@commandDiagnostics.Queued.ToString()" Footnote="Awaiting dispatch" />
            <StatCard Label="In Flight" Value="@((commandDiagnostics.Dispatched + commandDiagnostics.Acknowledged).ToString())" Footnote="Dispatched/acknowledged" />
            <StatCard Label="Failed" Value="@commandDiagnostics.Failed.ToString()" Footnote="@($"Command failures ({commandDiagnostics.RecentWindowMinutes}m)")" />
        </div>

        @if (daemonConnections.Count == 0)
        {
            <p class="text-small text-muted">No daemons are connected to the reverse channel.</p>
        }
        else
        {
            <ul class="list">
                @foreach (var connection in daemonConnections)
                {
                    <li class="list-item">
                        <div class="flex items-center justify-between gap-sm">
                            <strong>@connection.DaemonId</strong>
                            <span class="badge @(connection.IsOpen ? "badge-success" : "badge-warning")">
                                @(connection.IsOpen ? "Open" : "Closed")
                            </span>
                        </div>
                        <div class="text-small text-muted">Last seen: @connection.LastSeenUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                    </li>
                }
            </ul>
        }

        @if (!string.IsNullOrWhiteSpace(commandDiagnostics.LastFailure))
        {
            <p class="text-small text-muted mt-sm">Last queue failure: @commandDiagnostics.LastFailure</p>
        }
    </div>

    <div class="card mb-lg">
        <h2 class="card-title">Daemons</h2>
        @if (Daemons.Count == 0)
        {
            <p class="text-muted">No daemon groups configured.</p>
        }
        else
        {
            <ul class="list daemon-list">
                @foreach (var daemon in Daemons)
                {
                    var daemonWorkers = GetFilteredWorkersForDaemon(daemon);
                    var expanded = expandedDaemonIds.Contains(daemon.Id);
                    <li class="list-item daemon-item">
                        <div class="daemon-header-shell">
                            <button class="daemon-header" type="button" @onclick="() => ToggleDaemonExpand(daemon.Id)">
                                <div class="daemon-header-title">
                                    <span class="mdi @(expanded ? "mdi-chevron-down" : "mdi-chevron-right")"></span>
                                    <strong>@daemon.Name</strong>
                                </div>
                                <div class="daemon-header-stats">
                                    <span class="badge badge-info">@daemonWorkers.Count total</span>
                                    <span class="badge badge-success">@CountByStatus(daemonWorkers, "Active") active</span>
                                    <span class="badge badge-warning">@CountByStatus(daemonWorkers, "Paused") paused</span>
                                    <span class="badge badge-error">@CountByStatus(daemonWorkers, "Error") errors</span>
                                </div>
                            </button>
                            @if (daemonWorkers.Count > 0)
                            {
                                <div class="flex items-center gap-sm">
                                    <button class="btn btn-icon" @onclick="() => StartAllInDaemon(daemon)" type="button" title="Start all workers in this daemon" aria-label="Start all workers in this daemon">
                                        <span class="mdi mdi-play-network"></span>
                                    </button>
                                    <button class="btn btn-icon" @onclick="() => StopAllInDaemon(daemon)" type="button" title="Stop all workers in this daemon" aria-label="Stop all workers in this daemon">
                                        <span class="mdi mdi-stop-circle-outline"></span>
                                    </button>
                                </div>
                            }
                            @if (daemon.Id > 0)
                            {
                                <a class="btn btn-icon daemon-gear"
                                   href="@($"/workers/groups?daemonId={daemon.Id}")"
                                   title="Configure daemon"
                                   aria-label="Configure daemon">
                                    <span class="mdi mdi-cog"></span>
                                </a>
                            }
                        </div>

                        @if (expanded)
                        {
                            if (daemonWorkers.Count == 0)
                            {
                                <p class="text-small text-muted mt-sm">No workers in this daemon match current filters.</p>
                            }
                            else
                            {
                                <ul class="list daemon-worker-list">
                                    @foreach (var worker in daemonWorkers)
                                    {
                                        <li class="list-item worker-row worker-list-clickable" @onclick="() => OpenWorkerDetail(worker.Id)">
                                            <div class="worker-row-main">
                                                <div class="worker-title">@worker.Name</div>
                                                @{
                                                    var activity = GetWorkerActivity(worker);
                                                }
                                                <div class="text-small text-muted worker-url-row">
                                                    <HoverTooltip Text="@activity.Label" Class="worker-activity-tooltip-wrap">
                                                        <span class="mdi @activity.IconClass worker-activity-icon @activity.CssClass"></span>
                                                    </HoverTooltip>
                                                    <span class="worker-url-processing @(activity.IsProcessing ? "is-processing" : "")">
                                                        @(string.IsNullOrWhiteSpace(worker.CurrentUrl) ? "Waiting for next page..." : worker.CurrentUrl)
                                                    </span>
                                                    @if (activity.IsProcessing)
                                                    {
                                                        <span class="processing-ellipsis" aria-hidden="true">
                                                            <span></span><span></span><span></span>
                                                        </span>
                                                    }
                                                </div>
                                                <div class="text-small">Processed: @worker.PagesProcessed | Errors: @worker.ErrorCount</div>
                                                @if (!string.IsNullOrWhiteSpace(worker.StatusReason))
                                                {
                                                    <div class="text-small text-muted">Reason: @worker.StatusReason</div>
                                                }
                                            </div>
                                            <div class="worker-row-actions" @onclick:stopPropagation="true">
                                                <span class="badge @GetStatusBadgeClass(worker.Status)">@worker.Status</span>
                                                <button class="btn btn-icon" title="Logs" aria-label="Logs" @onclick='() => OpenWorkerSection(worker.Id, "logs")' type="button">
                                                    <span class="mdi mdi-text-box-search-outline"></span>
                                                </button>
                                                <button class="btn btn-icon" title="Metrics" aria-label="Metrics" @onclick='() => OpenWorkerSection(worker.Id, "metrics")' type="button">
                                                    <span class="mdi mdi-chart-line"></span>
                                                </button>
                                                <button class="btn btn-icon" title="Start" aria-label="Start" @onclick="() => Start(worker.Id)" type="button">
                                                    <span class="mdi mdi-play"></span>
                                                </button>
                                                <button class="btn btn-icon" title="Pause" aria-label="Pause" @onclick="() => Pause(worker.Id)" type="button">
                                                    <span class="mdi mdi-pause"></span>
                                                </button>
                                                <button class="btn btn-icon" title="Stop" aria-label="Stop" @onclick="() => Stop(worker.Id)" type="button">
                                                    <span class="mdi mdi-stop"></span>
                                                </button>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        }
                    </li>
                }
            </ul>
        }
    </div>

    <div class="card mb-lg">
        <div class="card-header-inline mb-sm">
            <h2 class="card-title mb-0">Daemon Combined Logs and Metrics</h2>
            <div class="flex items-center gap-sm">
                <span class="live-pill"><span class="live-dot"></span> Live</span>
                <span class="text-small text-muted">@GetCombinedLogSourceLabel()</span>
                <span class="text-small text-muted">@GetChannelStatusLabel()</span>
            </div>
        </div>
        <div class="workers-observability-toolbar mb-sm">
            <select @bind="CombinedSeverityFilter">
                <option value="all">All severities</option>
                <option value="Info">Info</option>
                <option value="Warning">Warning</option>
                <option value="Error">Error</option>
                <option value="Debug">Debug</option>
            </select>
            <input type="search" placeholder="Search log message..." @bind="CombinedLogSearch" @bind:event="oninput" />
        </div>

        <div class="grid grid-cols-3 mb-md">
            <StatCard Label="Throughput (1h)" Value="@GetCombinedThroughputTotal()" Footnote="pages processed" />
            <StatCard Label="Logs (filtered)" Value="@combinedLogs.Count.ToString()" Footnote="recent rows" />
            <StatCard Label="Warnings+Errors" Value="@combinedLogs.Count(log => IsWarnOrError(log.Level)).ToString()" Footnote="recent rows" />
        </div>

        <div class="mb-md">
            <div class="card-header-inline mb-xs">
                <h3 class="card-title mb-0">Throughput Trend</h3>
                <span class="text-small text-muted">@GetCombinedThroughputSourceLabel()</span>
            </div>
            @if (combinedThroughputSeries.Count == 0)
            {
                <p class="text-small text-muted">No throughput points yet.</p>
            }
            else
            {
                <ThroughputLineChart Points="combinedThroughputSeries" />
            }
        </div>

        <div class="workers-log-table-wrap">
            <table class="workers-log-table">
                <thead>
                    <tr>
                        <th>SEV</th>
                        <th>TS</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                    @if (combinedLogs.Count == 0)
                    {
                        <tr>
                            <td colspan="3" class="text-small text-muted">No logs in selected filter.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var log in combinedLogs.Take(80))
                        {
                            <tr>
                                <td><span class="badge @GetLogBadgeClass(log.Level)">@ToShortSeverity(log.Level)</span></td>
                                <td class="workers-log-ts">@log.TimestampUtc.ToLocalTime().ToString("HH:mm:ss")</td>
                                <td>
                                    @if (log.WorkerId.HasValue)
                                    {
                                        <span class="text-small text-muted">@($"w{log.WorkerId} · ")</span>
                                    }
                                    @log.Message
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="placeholder-note">
        <div class="placeholder-note-title">
            <span class="mdi mdi-server-network"></span> Daemon-based control model
        </div>
        <ul class="placeholder-note-list">
            @foreach (var item in WorkerApiPending)
            {
                <li>@item</li>
            }
        </ul>
    </div>
</div>

@code {
    private List<WorkerViewModel> workerItems = new();
    private List<WorkerGroupSettingsViewModel> daemonGroups = new();
    private List<DaemonChannelService.DaemonConnectionInfo> daemonConnections = new();
    private CommandQueueDiagnosticsViewModel commandDiagnostics = new();
    private List<WorkerLogEntryViewModel> combinedLogs = new();
    private List<WorkerThroughputPointViewModel> combinedThroughputSeries = new();
    private WorkerGlobalConfigViewModel? globalConfig;
    private DaemonStatusViewModel? daemonStatus;
    private string? actionStatus;
    private readonly HashSet<int> expandedDaemonIds = new();
    private PeriodicTimer? _refreshTimer;
    private CancellationTokenSource? _refreshCts;
    private string SearchTerm { get; set; } = "";
    private string StatusFilter { get; set; } = "ALL";
    private int SpawnGroupId { get; set; } = 1;
    private string SpawnMode { get; set; } = "thread";
    private string SpawnWorkerName { get; set; } = "";
    private string SpawnSeedUrlsText { get; set; } = "";
    private string CombinedSeverityFilter { get; set; } = "all";
    private string CombinedLogSearch { get; set; } = "";
    private bool combinedLogsUsingFallback;
    private bool combinedThroughputUsingFallback;

    private IReadOnlyList<string> WorkerApiPending =>
    [
        "One daemon API controls many workers; workers do not host nested APIs.",
        "Start daemon first, then spawn/start workers under that daemon.",
        "Use daemon-scoped config as defaults; worker config can override when needed.",
        "Expose API externally for remote workers; local worker coordination can stay in-process."
    ];

    private IReadOnlyList<string> Statuses => workerItems
        .Select(w => w.Status)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(s => s)
        .ToList();

    private List<WorkerGroupSettingsViewModel> Daemons => daemonGroups
        .OrderBy(group => group.Name)
        .ToList();

    private List<WorkerGroupSettingsViewModel> SpawnableDaemons => daemonGroups
        .Where(group => group.Id > 0)
        .OrderBy(group => group.Name)
        .ToList();

    private List<WorkerViewModel> FilteredWorkers => workerItems
        .Where(w => StatusFilter == "ALL" || string.Equals(w.Status, StatusFilter, StringComparison.OrdinalIgnoreCase))
        .Where(w => string.IsNullOrWhiteSpace(SearchTerm)
            || w.Name.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
            || (w.CurrentUrl?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(w => w.Name)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        globalConfig = await WorkerService.GetGlobalConfigAsync();

        _refreshCts = new CancellationTokenSource();
        _refreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(3));
        _ = Task.Run(async () =>
        {
            while (_refreshTimer is not null && await _refreshTimer.WaitForNextTickAsync(_refreshCts.Token))
            {
                await InvokeAsync(async () =>
                {
                    await RefreshAsync();
                    StateHasChanged();
                });
            }
        }, _refreshCts.Token);
    }

    private async Task RefreshAsync()
    {
        daemonStatus = await WorkerService.GetDaemonStatusAsync();
        workerItems = await WorkerService.GetAllWorkersAsync();
        daemonGroups = await WorkerService.GetWorkerGroupsAsync();
        var recentEvents = await WorkerService.GetRecentCrawlerEventsAsync(2000);
        daemonConnections = DaemonChannel.GetConnectionInfos().ToList();
        commandDiagnostics = await WorkerService.GetCommandQueueDiagnosticsAsync();
        combinedLogs = await WorkerService.GetPersistedWorkerLogsAsync(
            workerId: null,
            limit: 160,
            severity: CombinedSeverityFilter,
            search: CombinedLogSearch);
        combinedLogsUsingFallback = false;
        if (combinedLogs.Count == 0)
        {
            combinedLogs = BuildLogsFromCrawlerEvents(recentEvents, 160, CombinedSeverityFilter, CombinedLogSearch);
            combinedLogsUsingFallback = true;
        }
        combinedThroughputSeries = await WorkerService.GetThroughputSeriesAsync(workerId: null, windowMinutes: 60, bucketSeconds: 30);
        combinedThroughputUsingFallback = false;
        if (combinedThroughputSeries.Count == 0)
        {
            combinedThroughputSeries = BuildThroughputSeriesFromCrawlerEvents(recentEvents, windowMinutes: 60, bucketSeconds: 30);
            combinedThroughputUsingFallback = combinedThroughputSeries.Count > 0;
        }

        var groupedWorkerIds = daemonGroups
            .SelectMany(group => group.WorkerIds)
            .Distinct()
            .ToHashSet();
        var ungroupedWorkers = workerItems
            .Where(worker => !groupedWorkerIds.Contains(worker.Id))
            .Select(worker => worker.Id)
            .ToList();
        if (ungroupedWorkers.Count > 0)
        {
            daemonGroups.Add(new WorkerGroupSettingsViewModel
            {
                Id = -1,
                Name = "Ungrouped Workers",
                Description = "Workers not assigned to a daemon group yet.",
                Enabled = true,
                WorkerIds = ungroupedWorkers,
            });
        }

        if (daemonGroups.Count > 0 && daemonGroups.All(group => !expandedDaemonIds.Contains(group.Id)))
        {
            expandedDaemonIds.Add(daemonGroups[0].Id);
        }

        if (SpawnableDaemons.Count > 0 && SpawnableDaemons.All(group => group.Id != SpawnGroupId))
        {
            SpawnGroupId = SpawnableDaemons[0].Id;
        }

        if (daemonStatus == null && !string.IsNullOrWhiteSpace(WorkerService.LastError))
        {
            actionStatus = $"Daemon API unavailable: {WorkerService.LastError} Run: python pa1/crawler/src/daemon/main.py";
        }
    }

    private async Task Start(int id)
    {
        var ok = await WorkerService.StartWorkerAsync(id);
        actionStatus = ok
            ? $"Worker {id} start requested successfully."
            : $"Worker {id} start failed. {WorkerService.LastError}";
        await RefreshAsync();
    }

    private async Task Pause(int id)
    {
        var ok = await WorkerService.PauseWorkerAsync(id);
        actionStatus = ok
            ? $"Worker {id} pause requested successfully."
            : $"Worker {id} pause failed. {WorkerService.LastError}";
        await RefreshAsync();
    }

    private async Task Stop(int id)
    {
        var ok = await WorkerService.StopWorkerAsync(id);
        actionStatus = ok
            ? $"Worker {id} stop requested successfully."
            : $"Worker {id} stop failed. {WorkerService.LastError}";
        await RefreshAsync();
    }

    private async Task StartAllInDaemon(WorkerGroupSettingsViewModel daemon)
    {
        var targets = GetAllWorkersForDaemon(daemon)
            .Where(worker => !string.Equals(worker.Status, "Active", StringComparison.OrdinalIgnoreCase))
            .ToList();

        if (targets.Count == 0)
        {
            actionStatus = $"{daemon.Name}: no workers needed start.";
            return;
        }

        var success = 0;
        foreach (var worker in targets)
        {
            if (await WorkerService.StartWorkerAsync(worker.Id))
            {
                success++;
            }
        }

        actionStatus = $"{daemon.Name}: started {success}/{targets.Count} workers.";
        await RefreshAsync();
    }

    private async Task StopAllInDaemon(WorkerGroupSettingsViewModel daemon)
    {
        var targets = GetAllWorkersForDaemon(daemon)
            .Where(worker => !string.Equals(worker.Status, "Stopped", StringComparison.OrdinalIgnoreCase))
            .ToList();

        if (targets.Count == 0)
        {
            actionStatus = $"{daemon.Name}: no workers needed stop.";
            return;
        }

        var success = 0;
        foreach (var worker in targets)
        {
            if (await WorkerService.StopWorkerAsync(worker.Id))
            {
                success++;
            }
        }

        actionStatus = $"{daemon.Name}: stopped {success}/{targets.Count} workers.";
        await RefreshAsync();
    }

    private async Task SpawnWorker()
    {
        if (daemonStatus?.Running != true)
        {
            actionStatus = "Start daemon first, then spawn workers.";
            return;
        }

        if (SpawnGroupId <= 0)
        {
            actionStatus = "Select a daemon group before spawning a worker.";
            return;
        }

        var seedUrls = SpawnSeedUrlsText
            .Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(url => url.Trim())
            .Where(url => !string.IsNullOrWhiteSpace(url))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (seedUrls.Count == 0 && !string.IsNullOrWhiteSpace(globalConfig?.SeedUrlsText))
        {
            seedUrls = globalConfig.SeedUrlsText
                .Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(url => url.Trim())
                .Where(url => !string.IsNullOrWhiteSpace(url))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();
        }

        if (seedUrls.Count == 0 && globalConfig?.SeedEntries?.Count > 0)
        {
            seedUrls = globalConfig.SeedEntries
                .Where(entry => entry.Enabled && !string.IsNullOrWhiteSpace(entry.Url))
                .Select(entry => entry.Url.Trim())
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();
        }

        var spawned = await WorkerService.SpawnWorkerAsync(
            name: string.IsNullOrWhiteSpace(SpawnWorkerName) ? null : SpawnWorkerName.Trim(),
            daemonGroupId: SpawnGroupId,
            mode: SpawnMode,
            seedUrls: seedUrls);

        actionStatus = spawned == null
            ? $"Failed to spawn worker. {WorkerService.LastError}"
            : $"Spawned {spawned.Name} ({SpawnMode}) with {seedUrls.Count} seed URL(s).";

        if (spawned != null)
        {
            SpawnWorkerName = "";
            SpawnSeedUrlsText = "";
        }

        await RefreshAsync();
    }

    private async Task QuickStartCrawling()
    {
        if (globalConfig == null)
        {
            globalConfig = await WorkerService.GetGlobalConfigAsync();
        }

        if (daemonStatus?.Running != true)
        {
            var daemonStarted = await WorkerService.StartDaemonAsync();
            if (!daemonStarted)
            {
                actionStatus = $"Quick Start failed to start daemon. {WorkerService.LastError}";
                return;
            }
        }

        await RefreshAsync();

        var seeds = (globalConfig?.SeedEntries ?? new List<SeedEntryViewModel>())
            .Where(entry => entry.Enabled && !string.IsNullOrWhiteSpace(entry.Url))
            .Select(entry => entry.Url.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (seeds.Count == 0)
        {
            actionStatus = "Quick Start needs at least one enabled seed in Global Config.";
            return;
        }

        if (SpawnGroupId <= 0 && SpawnableDaemons.Count > 0)
        {
            SpawnGroupId = SpawnableDaemons[0].Id;
        }

        var selectedDaemon = Daemons.FirstOrDefault(group => group.Id == SpawnGroupId);
        var activeInSelectedDaemon = selectedDaemon != null
            && workerItems.Any(worker =>
                selectedDaemon.WorkerIds.Contains(worker.Id)
                && string.Equals(worker.Status, "Active", StringComparison.OrdinalIgnoreCase));

        if (!activeInSelectedDaemon)
        {
            var spawned = await WorkerService.SpawnWorkerAsync(
                name: $"Crawler-{DateTime.Now:HHmmss}",
                daemonGroupId: SpawnGroupId,
                mode: "thread",
                seedUrls: seeds);

            if (spawned == null)
            {
                actionStatus = $"Quick Start failed to spawn worker. {WorkerService.LastError}";
                return;
            }
        }

        if (selectedDaemon != null)
        {
            await StartAllInDaemon(selectedDaemon);
        }

        await RefreshAsync();
        actionStatus = "Quick Start complete: daemon running, seeds queued, workers active.";
    }

    private async Task ToggleDaemon()
    {
        if (daemonStatus?.Running == true)
        {
            var ok = await WorkerService.StopDaemonAsync();
            actionStatus = ok ? "Daemon stopped." : $"Failed to stop daemon. {WorkerService.LastError}";
        }
        else
        {
            var ok = await WorkerService.StartDaemonAsync();
            actionStatus = ok
                ? "Daemon started."
                : $"Failed to start daemon. {WorkerService.LastError ?? "Ensure crawler API server is running."}";
        }

        await RefreshAsync();
    }

    private async Task ReloadDaemon()
    {
        var ok = await WorkerService.ReloadDaemonAsync();
        actionStatus = ok ? "Daemon reloaded." : $"Failed to reload daemon. {WorkerService.LastError}";
        await RefreshAsync();
    }

