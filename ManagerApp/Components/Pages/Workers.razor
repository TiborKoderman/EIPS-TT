    private static bool TryRenderStatusTransition(string message, out string fromState, out string toState, out string details)
    {
        fromState = "Idle";
        toState = "Idle";
        details = message ?? string.Empty;
        if (string.IsNullOrWhiteSpace(message) || !message.Contains("[status-change]", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var text = message;
        var prevToken = "previousStatus=";
        var statusToken = "status=";
        var prevIdx = text.IndexOf(prevToken, StringComparison.OrdinalIgnoreCase);
        var statusIdx = text.IndexOf(statusToken, StringComparison.OrdinalIgnoreCase);
        if (statusIdx < 0)
        {
            return false;
        }

        if (prevIdx >= 0)
        {
            var prevStart = prevIdx + prevToken.Length;
            var prevEnd = text.IndexOf('|', prevStart);
            fromState = (prevEnd >= 0 ? text[prevStart..prevEnd] : text[prevStart..]).Trim();
        }

        var nextStart = statusIdx + statusToken.Length;
        var nextEnd = text.IndexOf('|', nextStart);
        toState = (nextEnd >= 0 ? text[nextStart..nextEnd] : text[nextStart..]).Trim();
        if (string.IsNullOrWhiteSpace(fromState))
        {
            fromState = "Idle";
        }
        if (string.IsNullOrWhiteSpace(toState))
        {
            toState = "Idle";
        }

        return true;
    }

