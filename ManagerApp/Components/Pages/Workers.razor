    private async Task SetDaemonRunningAsync(bool shouldRun)
    {
        daemonActionInProgress = true;
        daemonActionType = shouldRun ? "start" : "stop";

        try
        {
            bool ok;
            try
            {
                var operation = shouldRun
                    ? WorkerService.StartDaemonAsync()
                    : WorkerService.StopDaemonAsync();
                ok = await operation.WaitAsync(TimeSpan.FromSeconds(12));
            }
            catch (TimeoutException)
            {
                actionStatus = shouldRun
                    ? "Starting daemon timed out. Please retry and verify daemon logs."
                    : "Stopping daemon timed out. Please retry and verify daemon logs.";
                return;
            }

            actionStatus = shouldRun
                ? (ok
                    ? "Daemon started."
                    : $"Failed to start daemon. {WorkerService.LastError ?? "Ensure crawler API server is running."}")
                : (ok
                    ? "Daemon stopped."
                    : $"Failed to stop daemon. {WorkerService.LastError}");

            await RefreshAsync();
        }
        finally
        {
            daemonActionInProgress = false;
            daemonActionType = null;
        }
    }

