    private async Task QuickStartCrawling()
    {
        if (globalConfig == null)
        {
            globalConfig = await WorkerService.GetGlobalConfigAsync();
        }

        if (daemonStatus?.Running != true)
        {
            var daemonStarted = await WorkerService.StartDaemonAsync();
            if (!daemonStarted)
            {
                actionStatus = $"Quick Start failed to start daemon. {WorkerService.LastError}";
                return;
            }
        }

        await RefreshAsync();

        var seeds = (globalConfig?.SeedEntries ?? new List<SeedEntryViewModel>())
            .Where(entry => entry.Enabled && !string.IsNullOrWhiteSpace(entry.Url))
            .Select(entry => entry.Url.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (seeds.Count == 0)
        {
            actionStatus = "Quick Start needs at least one enabled seed in Global Config.";
            return;
        }

        if (string.IsNullOrWhiteSpace(SpawnTargetKey) && SpawnTargets.Count > 0)
        {
            SpawnTargetKey = SpawnTargets[0].Key;
        }

        var selectedTarget = SpawnTargets.FirstOrDefault(option => string.Equals(option.Key, SpawnTargetKey, StringComparison.OrdinalIgnoreCase));
        var selectedDaemon = selectedTarget is null
            ? null
            : Daemons.FirstOrDefault(group => group.Id == selectedTarget.GroupId
                && string.Equals(NormalizeDaemonId(group.DaemonId), selectedTarget.DaemonId, StringComparison.OrdinalIgnoreCase));
        var seeded = 0;
        foreach (var seed in seeds)
        {
            if (await WorkerService.AddSeedAsync(seed, null))
            {
                seeded++;
            }
        }

        var activeWorkerInSelectedDaemon = selectedDaemon is null
            ? null
            : workerItems.FirstOrDefault(worker =>
                selectedDaemon.WorkerIds.Contains(worker.Id)
                && string.Equals(worker.Status, "Active", StringComparison.OrdinalIgnoreCase));

        if (activeWorkerInSelectedDaemon is not null)
        {
            await RefreshAsync();
            actionStatus = seeded > 0
                ? $"Quick Start complete: queued {seeded} seed URL(s); worker {activeWorkerInSelectedDaemon.Id} is active."
                : $"Quick Start could not queue seeds. {WorkerService.LastError}";
            return;
        }

        WorkerViewModel? spawnedWorker = null;
        if (activeWorkerInSelectedDaemon is null)
        {
            spawnedWorker = await WorkerService.SpawnWorkerAsync(
                name: $"Crawler-{DateTime.Now:HHmmss}",
                daemonGroupId: selectedTarget?.GroupId,
                mode: "thread",
                seedUrls: null,
                daemonId: selectedTarget?.DaemonId);

            if (spawnedWorker == null)
            {
                actionStatus = $"Quick Start failed to spawn worker. {WorkerService.LastError}";
                return;
            }

            var started = await WorkerService.StartWorkerAsync(spawnedWorker.Id, spawnedWorker.DaemonId);
            if (!started)
            {
                actionStatus = $"Quick Start spawned worker {spawnedWorker.Id} but failed to start it. {WorkerService.LastError}";
                await RefreshAsync();
                return;
            }
        }

        await RefreshAsync();
        actionStatus = spawnedWorker is not null
            ? $"Quick Start complete: queued {seeded} seed URL(s); worker {spawnedWorker.Id} started and waiting on queue claims."
            : $"Quick Start complete: queued {seeded} seed URL(s); daemon running and workers active.";
    }

    private async Task StartDaemonFromDiagnostics()
