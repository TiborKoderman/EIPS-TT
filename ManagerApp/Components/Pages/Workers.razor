    private async Task SpawnWorker()
    {
        if (daemonStatus?.Running != true)
        {
            actionStatus = "Start daemon first, then spawn workers.";
            return;
        }

        var target = SpawnTargets.FirstOrDefault(option => string.Equals(option.Key, SpawnTargetKey, StringComparison.OrdinalIgnoreCase));
        if (target is null)
        {
            actionStatus = "Select a daemon group before spawning a worker.";
            return;
        }

        var count = Math.Clamp(SpawnCount, 1, 20);
        var success = 0;
        var seeds = GetSeedUrlsForSpawn();
        var queuedSeeds = 0;
        for (var i = 0; i < count; i++)
        {
            var spawned = await WorkerService.SpawnWorkerAsync(
                name: $"Worker-{DateTime.Now:HHmmss}-{i + 1}",
                daemonGroupId: target.GroupId,
                mode: SpawnMode,
                seedUrls: null,
                daemonId: target.DaemonId);

            if (spawned != null)
            {
                success++;
            }
        }

        foreach (var seed in seeds)
        {
            if (await WorkerService.AddSeedAsync(seed, null))
            {
                queuedSeeds++;
            }
        }

        actionStatus = success == 0
            ? $"Failed to spawn workers. {WorkerService.LastError}"
            : $"Spawned {success}/{count} workers in {SpawnMode} mode for daemon {target.DaemonId}. Queued seeds: {queuedSeeds}.";

        if (success > 0)
        {
            SpawnSeedUrlsText = "";
        }

        await RefreshAsync();
    }

    private async Task SpawnWorkersForDaemon(WorkerGroupSettingsViewModel daemon)
    {
        if (daemonStatus?.Running != true || daemonBulkInProgress)
        {
            return;
        }

        daemonBulkInProgress = true;
        var count = Math.Clamp(GetDaemonSpawnCount(daemon), 1, 20);
        var seeds = GetSeedUrlsForSpawn();
        var success = 0;
        var queuedSeeds = 0;

        for (var i = 0; i < count; i++)
        {
            var spawned = await WorkerService.SpawnWorkerAsync(
                name: $"{daemon.Name}-w-{DateTime.Now:HHmmss}-{i + 1}",
                daemonGroupId: daemon.Id,
                mode: SpawnMode,
                seedUrls: null,
                daemonId: daemon.DaemonId);
            if (spawned != null)
            {
                success++;
            }
        }

        foreach (var seed in seeds)
        {
            if (await WorkerService.AddSeedAsync(seed, null))
            {
                queuedSeeds++;
            }
        }

        actionStatus = success == 0
            ? $"{daemon.Name}: spawn failed. {WorkerService.LastError}"
            : $"{daemon.Name}: spawned {success}/{count} worker(s), queued seeds: {queuedSeeds}.";
        await RefreshAsync();
        daemonBulkInProgress = false;
    }

    private List<string> GetSeedUrlsForSpawn()
    {
        var seedUrls = SpawnSeedUrlsText
            .Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(url => url.Trim())
            .Where(url => !string.IsNullOrWhiteSpace(url))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (seedUrls.Count == 0 && !string.IsNullOrWhiteSpace(globalConfig?.SeedUrlsText))
        {
            seedUrls = globalConfig.SeedUrlsText
                .Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(url => url.Trim())
                .Where(url => !string.IsNullOrWhiteSpace(url))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();
        }

        if (seedUrls.Count == 0 && globalConfig?.SeedEntries?.Count > 0)
        {
            seedUrls = globalConfig.SeedEntries
                .Where(entry => entry.Enabled && !string.IsNullOrWhiteSpace(entry.Url))
                .Select(entry => entry.Url.Trim())
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();
        }

        return seedUrls;
    }

    private async Task ExecuteWorkerAction(WorkerViewModel worker, string actionName, Func<Task<bool>> action)
    {
        var workerId = worker.Id;
        if (workerActionInProgress.Contains(workerId))
        {
            return;
        }

        workerActionInProgress.Add(workerId);
        workerActionTypeInProgress[workerId] = actionName;
        actionStatus = $"Worker {workerId} ({NormalizeDaemonId(worker.DaemonId)}): {actionName}...";
        StateHasChanged();

        try
        {
            var ok = await action();
            actionStatus = ok
                ? $"Worker {workerId} ({NormalizeDaemonId(worker.DaemonId)}) {actionName} requested successfully."
                : $"Worker {workerId} ({NormalizeDaemonId(worker.DaemonId)}) {actionName} failed. {WorkerService.LastError}";
            await RefreshAsync();
        }
        finally
        {
            workerActionInProgress.Remove(workerId);
            workerActionTypeInProgress.Remove(workerId);
        }
    }

    private async Task<int> ExecuteBatchWorkerAction(IEnumerable<WorkerViewModel> workers, Func<WorkerViewModel, Task<bool>> action)
    {
        var workerList = workers
            .GroupBy(worker => $"{NormalizeDaemonId(worker.DaemonId)}:{worker.Id}", StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .ToList();

        var tasks = workerList.Select(async worker =>
        {
            var id = worker.Id;
            workerActionInProgress.Add(id);
            try
            {
                return await action(worker) ? 1 : 0;
            }
            finally
            {
                workerActionInProgress.Remove(id);
            }
        }).ToList();

        var results = await Task.WhenAll(tasks);
        return results.Sum();
    }

