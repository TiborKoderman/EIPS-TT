@page "/graph"
@using System.Text.Json
@using ManagerApp.Models
@using ManagerApp.Services
@inject IGraphService GraphService
@inject IJSRuntime Js
@implements IAsyncDisposable

<div class="page-header">
    <h1 class="page-title">Node Graph</h1>
    <p class="page-subtitle">Interactive page-link topology powered by D3</p>
</div>

<div class="page-body">
    <div class="card mb-lg">
        <div class="flex items-center gap-md">
            <label class="text-small text-muted">Visible node limit</label>
            <select @bind="VisibleNodeLimit">
                <option value="250">250</option>
                <option value="500">500</option>
                <option value="1000">1000</option>
                <option value="2000">2000</option>
            </select>
            <button class="btn btn-primary" @onclick="ReloadGraph">
                <span class="mdi mdi-refresh"></span> Reload
            </button>
            <span class="text-small text-muted">Loaded: @GraphData.Nodes.Count nodes, @GraphData.Links.Count links</span>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="card"><p>Loading graph data...</p></div>
    }
    else if (!string.IsNullOrWhiteSpace(Error))
    {
        <div class="card"><p class="text-muted">@Error</p></div>
    }
    else
    {
        <div class="card mb-lg graph-card">
            <div class="graph-shell">
                <div class="graph-main">
                    <div class="graph-toolbar">
                        <input type="search" placeholder="Search URL/domain..." @bind="SearchTerm" @bind:event="oninput" />
                        <button class="btn" @onclick="FocusSearch"><span class="mdi mdi-crosshairs-gps"></span> Focus</button>
                        <button class="btn" @onclick="ExportSvg"><span class="mdi mdi-file-image"></span> Export SVG</button>
                    </div>
                    <div id="@GraphHostId" class="graph-canvas" style="height:640px;"></div>
                </div>
            </div>
        </div>
    }

    <div class="placeholder-note">
        <div class="placeholder-note-title">
            <span class="mdi mdi-tools"></span> Pending crawler capabilities for full live graph
        </div>
        <ul class="placeholder-note-list">
            @foreach (var item in GraphPending)
            {
                <li>@item</li>
            }
        </ul>
    </div>
</div>

@code {
    private GraphDataDto GraphData = new();
    private int VisibleNodeLimit = 500;
    private bool IsLoading = true;
    private string? Error;
    private string? SearchTerm;
    private readonly string GraphHostId = $"graph_{Guid.NewGuid():N}";
    private IJSObjectReference? _graphModule;
    private readonly CancellationTokenSource _refreshCts = new();
    private Task? _refreshTask;

    private IReadOnlyList<string> GraphPending =>
    [
        "Graph now keeps zoom and simulation state between reloads instead of resetting the camera.",
        "Zoomed-out view groups island components; zooming in progressively reveals more edges.",
        "Seeds start centered and spread out, and newly discovered nodes spawn near active worker markers.",
        "Graph export supports SVG output."
    ];

    protected override async Task OnInitializedAsync()
    {
        await ReloadGraph();
        _refreshTask = RunAutoRefreshLoopAsync(_refreshCts.Token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _graphModule = await Js.InvokeAsync<IJSObjectReference>("import", "./js/graph.js");
        }

        await TryRenderGraphAsync();
    }

    private async Task ReloadGraph()
    {
        IsLoading = true;
        Error = null;

        try
        {
            GraphData = await GraphService.GetGraphDataAsync(VisibleNodeLimit);
        }
        catch (Exception ex)
        {
            Error = $"Unable to load graph data: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }

        await TryRenderGraphAsync();
    }

    private async Task RunAutoRefreshLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(4));
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                if (!await timer.WaitForNextTickAsync(cancellationToken))
                {
                    break;
                }
            }
            catch (OperationCanceledException)
            {
                break;
            }

            await InvokeAsync(async () =>
            {
                if (!IsLoading)
                {
                    await ReloadGraph();
                    StateHasChanged();
                }
            });
        }
    }

    private async Task TryRenderGraphAsync()
    {
        if (_graphModule == null || IsLoading || !string.IsNullOrWhiteSpace(Error) || GraphData.Nodes.Count == 0)
        {
            return;
        }

        var payload = JsonSerializer.Serialize(GraphData);
        await _graphModule.InvokeVoidAsync("renderGraph", GraphHostId, payload);
    }

    private async Task FocusSearch()
    {
        if (_graphModule == null || string.IsNullOrWhiteSpace(SearchTerm))
        {
            return;
        }

        await _graphModule.InvokeVoidAsync("focusNode", GraphHostId, SearchTerm.Trim());
    }

    private async Task ExportSvg()
    {
        if (_graphModule == null)
        {
            return;
        }

        await _graphModule.InvokeVoidAsync("exportSvg", GraphHostId, $"crawler-graph-{DateTime.UtcNow:yyyyMMdd-HHmmss}.svg");
    }

    public async ValueTask DisposeAsync()
    {
        _refreshCts.Cancel();
        if (_refreshTask is not null)
        {
            try
            {
                await _refreshTask;
            }
            catch (OperationCanceledException)
            {
                // Expected on disposal.
            }
        }

        _refreshCts.Dispose();
        if (_graphModule != null)
        {
            try
            {
                await _graphModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Safe to ignore when browser circuit is already disconnected.
            }
        }
    }
}
