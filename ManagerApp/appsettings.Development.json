{
  "CrawlerApi": {
    "BaseUrl": "http://127.0.0.1:8090",
    "Token": "",
    "DaemonChannelToken": "",
    "AutoStartLocalDaemon": true,
    "EnsureLocalDaemonWorkerOnStartup": true,
    "UseReverseChannelCommands": true,
    "EnableCommandDispatch": true,
    "CommandDispatchPollMs": 1000,
    "ObservabilityCleanupMinutes": 30,
    "WorkerLogRetentionDays": 14,
    "WorkerMetricRetentionDays": 30,
    "DefaultDaemonDbId": 1,
    "LauncherMode": "Process",
    "PythonExecutable": ".venv/bin/python",
    "LocalDaemonArgs": "pa1/crawler/src/main.py",
    "ManagerBaseUrl": "",
    "ManagerSocketUrl": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
