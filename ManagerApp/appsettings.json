{
  "ConnectionStrings": {
    "CrawldbConnection": "Host=localhost;Port=5432;Database=crawldb;Username=postgres;Password=postgres"
  },
  "CrawlerApi": {
    "BaseUrl": "http://127.0.0.1:8090",
    "Token": "",
    "AutoStartLocalDaemon": true,
    "UseReverseChannelCommands": true,
    "EnableCommandDispatch": true,
    "CommandDispatchPollMs": 1000,
    "ObservabilityCleanupMinutes": 30,
    "WorkerLogRetentionDays": 14,
    "WorkerMetricRetentionDays": 30,
    "DefaultDaemonDbId": 1,
    "LauncherMode": "Process",
    "PythonExecutable": ".venv/bin/python",
    "LocalDaemonArgs": "pa1/crawler/src/daemon/main.py",
    "ManagerBaseUrl": "",
    "ManagerSocketUrl": "",
    "DockerStartCommand": "docker compose --profile daemon up -d crawler-daemon",
    "DockerStopCommand": "docker compose --profile daemon stop crawler-daemon"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*"
}
